# PR-Daemon local secrets. Copy to .env and do not commit .env.

# Keep jhfnetboy as the default discovery/fetch account.
PR_DAEMON_MAIN_USER=jhfnetboy

# Review account used only when posting GitHub PR reviews.
PR_DAEMON_REVIEW_USER=clestons

# Optional: use this token only for posting reviews, without changing gh's
# globally active account. Prefer a fine-grained token scoped to the target org/repo.
# Do not paste the real token into chat or commit it.
PR_DAEMON_REVIEW_TOKEN=

# Optional host override.
PR_DAEMON_GH_HOST=github.com

# Optional proxy settings for Codex CLI, gh, curl, and first-pass HTTP calls.
# PR-Daemon does not automatically read the macOS system proxy; set these in .env
# if your terminal traffic must go through a proxy.
PR_DAEMON_HTTPS_PROXY=
PR_DAEMON_HTTP_PROXY=
PR_DAEMON_ALL_PROXY=
PR_DAEMON_NO_PROXY=127.0.0.1,localhost

# First-pass reviewer routing:
# If these are set, PR-Daemon will use this OpenAI-compatible endpoint first
# for broad PR review, then fall back to the local Rapid-MLX server if the
# provider fails or quota is exhausted.
PR_DAEMON_FIRST_PASS_PROVIDER=deepseek
PR_DAEMON_FIRST_PASS_BASE_URL=
PR_DAEMON_FIRST_PASS_MODEL=
PR_DAEMON_FIRST_PASS_API_KEY=
PR_DAEMON_FIRST_PASS_THINKING=disabled
PR_DAEMON_FIRST_PASS_REASONING_EFFORT=

# Fallback first-pass reviewer (optional offline fallback — not required).
# Only called if the primary first-pass provider above fails.
PR_DAEMON_FALLBACK_PROVIDER=rapid-mlx
PR_DAEMON_FALLBACK_BASE_URL=http://127.0.0.1:8000/v1
PR_DAEMON_FALLBACK_MODEL=qwen3.6-a3b
PR_DAEMON_FALLBACK_API_KEY=
PR_DAEMON_FALLBACK_THINKING=
PR_DAEMON_FALLBACK_REASONING_EFFORT=

# Deep reviewer CLI settings.
# PR_DAEMON_REVIEWER_CLI=claude      — primary: run-dpsk-claude.sh launches claude on DeepSeek API
# PR_DAEMON_REVIEWER_FALLBACK=codex  — fallback if claude binary or run-dpsk-claude.sh is missing
PR_DAEMON_REVIEWER_CLI=claude
PR_DAEMON_REVIEWER_FALLBACK=codex
PR_DAEMON_REVIEWER_MODEL=opus
PR_DAEMON_REVIEWER_TIMEOUT=1800
PR_DAEMON_REVIEWER_MAX_TURNS=40

# DeepSeek API key (used by run-dpsk-claude.sh to route Claude Code to DeepSeek backend)
DEEPSEEK_API_KEY=
